# Local Postgres (used by docker compose)
POSTGRES_DB=fraud_ops
POSTGRES_USER=fraud_app
POSTGRES_PASSWORD=fraud_app_password

# Backend database connection
# Use your Supabase Postgres connection string if you are not running local Postgres.
DATABASE_URL=postgresql+psycopg://fraud_app:fraud_app_password@postgres:5432/fraud_ops

# Clerk backend verification
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Optional alternative to CLERK_JWT_KEY:
# CLERK_PEM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CLERK_JWT_ALGORITHMS=RS256
CLERK_ISSUER=
CLERK_AUDIENCE=

# App bootstrap and CORS
BOOTSTRAP_HISTORY=true
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Internal role mapping
ANALYST_USERNAME=analyst
ANALYST_CLERK_USER_ID=user_replace_with_clerk_analyst_id
MANAGER_USERNAME=admin
MANAGER_CLERK_USER_ID=user_replace_with_clerk_manager_id

# Frontend / Clerk
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_replace_with_clerk_secret_key
