{
  "title": "FraudPipelineOutput",
  "type": "object",
  "required": [
    "transaction_id",
    "pipeline_profile",
    "final_risk_score",
    "risk_bucket",
    "decision",
    "model_scores",
    "required_state_status",
    "explanations"
  ],
  "properties": {
    "transaction_id": {
      "type": "string"
    },
    "pipeline_profile": {
      "type": "string",
      "description": "Active model profile used for inference."
    },
    "final_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_bucket": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "review",
        "block"
      ]
    },
    "model_scores": {
      "type": "object",
      "required": [
        "event_gnn",
        "adaboost",
        "lightgbm"
      ],
      "properties": {
        "event_gnn": {
          "type": "number"
        },
        "adaboost": {
          "type": "number"
        },
        "lightgbm": {
          "type": "number"
        }
      }
    },
    "required_state_status": {
      "type": "object",
      "required": [
        "history_available",
        "graph_context_available"
      ],
      "properties": {
        "history_available": {
          "type": "boolean"
        },
        "graph_context_available": {
          "type": "boolean"
        }
      }
    },
    "routing_metadata": {
      "type": "object"
    },
    "explanations": {
      "type": "object",
      "required": [
        "tabular_risk_factors",
        "event_context_summary"
      ],
      "properties": {
        "tabular_risk_factors": {
          "type": "array"
        },
        "event_context_summary": {
          "type": "array"
        }
      }
    }
  },
  "additionalProperties": false
}
