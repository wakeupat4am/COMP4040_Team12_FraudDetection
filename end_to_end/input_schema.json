{
  "title": "FraudTransactionInput",
  "type": "object",
  "required": [
    "transaction_id",
    "transaction_timestamp",
    "sender_id",
    "receiver_id",
    "amount",
    "transaction_location",
    "transaction_type"
  ],
  "properties": {
    "transaction_id": {
      "type": "string",
      "description": "Unique identifier for the transaction."
    },
    "transaction_timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp for the transaction event."
    },
    "sender_id": {
      "type": "string",
      "description": "Originating account or sender identifier."
    },
    "receiver_id": {
      "type": "string",
      "description": "Receiving account or target identifier."
    },
    "amount": {
      "type": "number",
      "minimum": 0,
      "description": "Non-negative transaction amount."
    },
    "transaction_location": {
      "type": "string",
      "description": "Location token associated with the transaction."
    },
    "transaction_type": {
      "type": "string",
      "description": "Transaction type token."
    },
    "currency": {
      "type": "string",
      "description": "Optional transaction currency."
    },
    "channel": {
      "type": "string",
      "description": "Optional transaction channel, such as web or mobile."
    },
    "raw_attributes": {
      "type": "object",
      "description": "Optional additional raw immutable attributes supplied by the caller."
    }
  },
  "additionalProperties": false
}
